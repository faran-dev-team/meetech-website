# ============================================================
# MEETECH WEBSITE — ENVIRONMENT VARIABLES
# Copy this file to .env.local for local development.
# On Vercel, add every variable via the dashboard (Settings → Environment Variables).
# ============================================================

# ── Database (MongoDB Atlas) ──────────────────────────────────────────────────
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
# Add &maxPoolSize=1 for Vercel serverless (prevents connection exhaustion)
DATABASE_URL="mongodb+srv://USER:PASSWORD@cluster.mongodb.net/meetech?retryWrites=true&w=majority&maxPoolSize=1"

# ── NextAuth.js ───────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-32-char-random-secret"
# Your production domain (no trailing slash)
NEXTAUTH_URL="https://your-domain.com"
# Must match NEXTAUTH_URL
NEXT_PUBLIC_APP_URL="https://your-domain.com"

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_PUBLISHABLE_KEY="pk_live_..."
# Set in Stripe Dashboard → Webhooks → your endpoint secret
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY="re_..."
# Must be a verified sender domain in Resend
RESEND_FROM_EMAIL="noreply@your-domain.com"

# ── Sanity CMS ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID="your-sanity-project-id"
NEXT_PUBLIC_SANITY_DATASET="production"
# Read-only token for server-side fetching (create in manage.sanity.io)
SANITY_API_TOKEN="sk..."
# Random string used to validate Sanity webhook calls
SANITY_WEBHOOK_SECRET="replace-with-random-string"

# ── Vercel Blob Storage ───────────────────────────────────────────────────────
# Auto-provided when you enable Blob Storage in Vercel dashboard
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# ── Analytics (Google Analytics 4) ───────────────────────────────────────────
# Optional — leave empty to disable GA4
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# ── Slack Notifications ───────────────────────────────────────────────────────
# Optional — incoming webhook URL from Slack app settings
SLACK_WEBHOOK_URL="https://hooks.slack.com/services/..."

# ── Node environment ──────────────────────────────────────────────────────────
NODE_ENV="production"
