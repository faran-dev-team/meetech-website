{
  "framework": "nextjs",
  "buildCommand": "prisma generate && next build",
  "installCommand": "npm ci",
  "outputDirectory": ".next",
  "regions": ["iad1"],
  "functions": {
    "app/api/stripe/webhook/route.ts": {
      "maxDuration": 30
    },
    "app/api/projects/**": {
      "maxDuration": 30
    },
    "app/api/leads/**": {
      "maxDuration": 15
    },
    "app/api/analytics/**": {
      "maxDuration": 15
    },
    "app/api/messages/**": {
      "maxDuration": 15
    },
    "app/api/users/**": {
      "maxDuration": 15
    },
    "app/api/meeting-requests/**": {
      "maxDuration": 15
    },
    "app/api/change-requests/**": {
      "maxDuration": 15
    },
    "app/api/auth/**": {
      "maxDuration": 10
    },
    "app/api/content/**": {
      "maxDuration": 10
    }
  },
  "crons": []
}
