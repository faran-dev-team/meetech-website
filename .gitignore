# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

.env
# testing
/coverage
.nyc_output

# next.js
/.next/
/out/

# production
/build
dist/

# misc
.DS_Store
*.pem
Thumbs.db

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — block all local/secret variants, but allow the example template
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
# explicitly allow the template file
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Prisma
prisma/migrations/

# Sanity
sanity-studio/.sanity
sanity-studio/dist

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Misc
*.tmp
.cache/
